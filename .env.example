# Database
DATABASE_URL=postgresql+asyncpg://serpnex:serpnex@localhost:5432/serpnex
DATABASE_URL_SYNC=postgresql+psycopg2://serpnex:serpnex@localhost:5432/serpnex

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Crawler provider
# Implementation: firecrawl
CRAWLER_PROVIDER=firecrawl
FIRECRAWL_API_KEY=

# Search data provider
# Implementation: dataforseo
SEARCH_DATA_PROVIDER=dataforseo
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# LLM provider
# Implementation: anthropic
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# GSC provider
# Implementation: google
GSC_PROVIDER=google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/gsc/callback
